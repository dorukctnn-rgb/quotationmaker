<script>
let color = '#0f4c81';

function setColor(el) {
  document.querySelectorAll('.cdot').forEach(d => d.classList.remove('on'));
  el.classList.add('on');
  color = el.dataset.c;
  up();
}

function sym() {
  return document.getElementById('currency').value.split('|')[1] || '$';
}

function getItems() {
  const rows = document.querySelectorAll('.ir');
  const r = [];
  rows.forEach(row => {
    const ins = row.querySelectorAll('input');
    if (ins.length >= 3) {
      const desc = ins[0].value, qty = parseFloat(ins[1].value)||0, rate = parseFloat(ins[2].value)||0;
      row.querySelector('.lt').textContent = sym() + (qty*rate).toFixed(2);
      r.push({ desc, qty, rate });
    }
  });
  return r;
}

function calcs(items) {
  const s = sym();
  const sub = items.reduce((a,i) => a + i.qty*i.rate, 0);
  const tr = parseFloat(document.getElementById('taxRate').value)||0;
  const tl = document.getElementById('taxLabel').value||'Tax';
  const disc = parseFloat(document.getElementById('discount').value)||0;
  const discType = document.getElementById('discountType').value;
  const discAmt = discType === 'percent' ? sub*(disc/100) : disc;
  const afterDisc = sub - discAmt;
  const ta = afterDisc * (tr/100);
  const tot = afterDisc + ta;

  document.getElementById('sub').textContent = s + sub.toFixed(2);
  document.getElementById('tot').textContent = s + tot.toFixed(2);

  const discrow = document.getElementById('discrow');
  if (discAmt > 0) {
    discrow.style.display = 'flex';
    document.getElementById('discLabel').textContent = 'Discount' + (discType==='percent'?' ('+disc+'%)':'');
    document.getElementById('discDisplay').textContent = '-' + s + discAmt.toFixed(2);
  } else {
    discrow.style.display = 'none';
  }

  const taxrow = document.getElementById('taxrow');
  if (tr > 0) {
    taxrow.style.display = 'flex';
    document.getElementById('tlabel').textContent = tl + ' (' + tr + '%)';
    document.getElementById('taxamt').textContent = s + ta.toFixed(2);
  } else {
    taxrow.style.display = 'none';
  }

  return { sub, ta, tot, tr, tl, discAmt, discType, disc, afterDisc };
}

function buildPreviewHTML(d) {
  const s = d.symbol || '$';
  const c = d.color || '#0f4c81';
  const rows = (d.items||[]).map(i => {
    const amt = (i.qty*i.rate).toFixed(2);
    return `<tr>
      <td style="padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:12px">${i.desc||''}</td>
      <td style="padding:7px 6px;border-bottom:1px solid #f0f0f0;text-align:center;font-size:12px;color:#666">${i.qty}</td>
      <td style="padding:7px 6px;border-bottom:1px solid #f0f0f0;text-align:right;font-size:12px;color:#666">${s}${parseFloat(i.rate).toFixed(2)}</td>
      <td style="padding:7px 0 7px 6px;border-bottom:1px solid #f0f0f0;text-align:right;font-size:12px;font-weight:700">${s}${amt}</td>
    </tr>`;
  }).join('');

  const discRow = d.discAmt > 0 ? `<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:11px;color:#dc2626;border-top:1px solid #f0f0f0"><span>Discount${d.discType==='percent'?' ('+d.disc+'%)':''}</span><span>-${s}${d.discAmt.toFixed(2)}</span></div>` : '';
  const taxRow = d.tr > 0 ? `<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:11px;color:#666;border-top:1px solid #f0f0f0"><span>${d.tl||'Tax'} (${d.tr}%)</span><span>${s}${d.ta.toFixed(2)}</span></div>` : '';
  const validWarn = d.validUntil ? `<div style="background:#fff5f5;border:1px solid #fed7d7;border-radius:5px;padding:8px 12px;margin-bottom:12px"><p style="font-size:10px;color:#c53030;margin:0">&#9888; Valid until <strong>${d.validUntil}</strong></p></div>` : '';

  return `<!DOCTYPE html><html><head><link rel="icon" type="image/svg+xml" href="/favicon.svg"><meta charset="UTF-8"><meta name="google-site-verification" content="SRbRrdv1CAaGtpC67I5g5htAbMp2LmyqfylqDAKWvK0"><style>body{font-family:Arial,sans-serif;color:#1a1a1a;margin:0;padding:20px;font-size:12px}*{box-sizing:border-box}</style></head><body>
<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:18px;padding-bottom:14px;border-bottom:3px solid ${c}">
  <div><div style="font-size:20px;font-weight:800;color:${c}">QUOTATION</div><div style="color:#999;font-size:10px;margin-top:2px">#${d.quoteNumber||'Q-001'}</div></div>
  <div style="text-align:right"><div style="font-weight:700;font-size:13px">${d.fromName||''}</div><div style="color:#666;font-size:10px">${d.fromEmail||''}</div><div style="color:#666;font-size:10px;white-space:pre-line">${(d.fromAddress||'').replace(/\n/g,'<br>')}</div></div>
</div>
<div style="display:flex;justify-content:space-between;margin-bottom:16px">
  <div><div style="font-size:9px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px">Prepared For</div><div style="font-weight:700;font-size:12px">${d.toName||''}</div><div style="color:#666;font-size:10px">${d.toEmail||''}</div><div style="color:#666;font-size:10px;white-space:pre-line">${(d.toAddress||'').replace(/\n/g,'<br>')}</div></div>
  <div style="text-align:right"><div style="margin-bottom:5px"><div style="font-size:9px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:.5px">Quote Date</div><div style="font-weight:700;font-size:11px">${d.quoteDate||''}</div></div>${d.validUntil?`<div><div style="font-size:9px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:.5px">Valid Until</div><div style="font-weight:700;font-size:11px;color:#dc2626">${d.validUntil}</div></div>`:''}</div>
</div>
${validWarn}
<table style="width:100%;border-collapse:collapse;margin-bottom:14px">
  <thead><tr style="background:${c}"><th style="padding:8px 0;text-align:left;font-size:9px;font-weight:700;color:#fff;letter-spacing:.5px">DESCRIPTION</th><th style="padding:8px 6px;text-align:center;font-size:9px;font-weight:700;color:#fff">QTY</th><th style="padding:8px 6px;text-align:right;font-size:9px;font-weight:700;color:#fff">RATE</th><th style="padding:8px 0 8px 6px;text-align:right;font-size:9px;font-weight:700;color:#fff">AMOUNT</th></tr></thead>
  <tbody>${rows}</tbody>
</table>
<div style="display:flex;justify-content:flex-end;margin-bottom:14px">
  <div style="min-width:190px">
    <div style="display:flex;justify-content:space-between;padding:3px 0;font-size:11px;color:#666"><span>Subtotal</span><span>${s}${d.sub.toFixed(2)}</span></div>
    ${discRow}${taxRow}
    <div style="display:flex;justify-content:space-between;padding:8px 0 3px;font-size:15px;font-weight:800;border-top:2px solid ${c};margin-top:3px"><span>Total</span><span style="color:${c}">${s}${d.tot.toFixed(2)}</span></div>
  </div>
</div>
${d.notes?`<div style="background:#f8f9fa;border-left:3px solid ${c};padding:9px 13px;border-radius:0 5px 5px 0"><div style="font-size:9px;font-weight:700;color:#999;text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px">Notes & Terms</div><div style="font-size:11px;color:#555;line-height:1.6">${d.notes}</div></div>`:''}
<div style="text-align:center;margin-top:20px;padding-top:12px;border-top:1px solid #eee"><p style="font-size:9px;color:#bbb;margin:0">Created free at <strong>GetQuotationMaker.com</strong></p></div>
</body></html>`;
}

function up() {
  const items = getItems();
  const { sub, ta, tot, tr, tl, discAmt, discType, disc, afterDisc } = calcs(items);
  const s = sym();
  const validUntil = document.getElementById('validUntil').value;

  document.getElementById('validity-warn').style.display = validUntil ? 'flex' : 'none';

  const d = {
    fromName: document.getElementById('fromName').value,
    fromEmail: document.getElementById('fromEmail').value,
    fromAddress: document.getElementById('fromAddress').value,
    toName: document.getElementById('toName').value,
    toEmail: document.getElementById('toEmail').value,
    toAddress: document.getElementById('toAddress').value,
    quoteNumber: document.getElementById('quoteNumber').value,
    quoteDate: document.getElementById('quoteDate').value,
    validUntil,
    notes: document.getElementById('notes').value,
    tr, tl, ta, sub, tot, discAmt, discType, disc, afterDisc,
    items, color, symbol: s
  };
  document.getElementById('pframe').srcdoc = buildPreviewHTML(d);
}

function addItem() {
  const c = document.getElementById('items');
  const div = document.createElement('div');
  div.className = 'ir';
  div.innerHTML = '<input type="text" placeholder="Service or product" oninput="up()"><input type="number" value="1" min="0" step="any" oninput="up()"><input type="number" value="0" min="0" step="any" oninput="up()"><div class="lt">$0.00</div><button class="del" onclick="delItem(this)" title="Remove">&#215;</button>';
  c.appendChild(div);
  up();
}

function delItem(btn) {
  if (document.querySelectorAll('.ir').length > 1) { btn.parentElement.remove(); up(); }
}

function toggleFaq(el) {
  el.classList.toggle('open');
  el.querySelector('h3 span').textContent = el.classList.contains('open') ? 'âˆ’' : '+';
}

async function dlPDF() {
  const btn = document.getElementById('pbtn');
  btn.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Generating...';
  btn.disabled = true;

  const items = getItems();
  const { sub, ta, tot, tr, tl, discAmt, discType, disc } = calcs(items);
  const s = sym();

  const d = {
    fromName: document.getElementById('fromName').value,
    fromEmail: document.getElementById('fromEmail').value,
    fromAddress: document.getElementById('fromAddress').value,
    toName: document.getElementById('toName').value,
    toEmail: document.getElementById('toEmail').value,
    toAddress: document.getElementById('toAddress').value,
    quoteNumber: document.getElementById('quoteNumber').value,
    quoteDate: document.getElementById('quoteDate').value,
    validUntil: document.getElementById('validUntil').value,
    notes: document.getElementById('notes').value,
    taxRate: tr, taxLabel: tl, taxAmt: ta, subtotal: sub, total: tot,
    discount: disc, discountType: discType,
    items, color, symbol: s
  };

  try {
    const res = await fetch('/generate-pdf', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ quoteData: JSON.stringify(d) }) });
    if (!res.ok) throw new Error();
    const blob = await res.blob();
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'quote-' + (d.quoteNumber||'Q-001') + '.pdf'; a.click();
    URL.revokeObjectURL(url);
    btn.innerHTML = '<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Download Free PDF Quote';
    btn.disabled = false;
  } catch(e) {
    btn.textContent = 'Error â€” try again';
    btn.disabled = false;
  }
}

// Init
const today = new Date().toISOString().split('T')[0];
const plus30 = new Date(Date.now() + 30*864e5).toISOString().split('T')[0];
document.getElementById('quoteDate').value = today;
document.getElementById('validUntil').value = plus30;
up();
</script>
</body>
</html>





