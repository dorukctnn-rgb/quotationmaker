<div class="breadcrumb"><a href="/">Home</a> â€º By Country â€º <%= country.fullName %></div>

<section class="hero">
  <div class="badge"><%= country.currency %> &bull; Auto <%= country.tax %> &bull; Free PDF</div>
  <h1>Free Quote Generator<br><%= country.fullName %></h1>
  <p>Create professional <%= country.currency %> quotations with automatic <%= country.tax %> calculation. Download PDF instantly â€” no signup, no watermark on PRO.</p>
  <div class="trust">
    <span class="trust-item"><span class="tdot"></span>Auto <%= country.tax %> (<%= country.taxRate %>%)</span>
    <span class="trust-item"><span class="tdot"></span><%= country.currency %> pre-selected</span>
    <span class="trust-item"><span class="tdot"></span>Free PDF download</span>
    <span class="trust-item"><span class="tdot"></span>No signup needed</span>
  </div>
  <div class="tax-box">
    <p>&#9432; The standard <%= country.tax %> rate in <%= country.fullName %> is <strong><%= country.taxRate %>%</strong> â€” pre-filled for you. Adjust if your services have a different rate.</p>
  </div>
</section>

<div class="main">
  <div>
    <div class="card">
      <div class="stitle">Your details</div>
      <div class="frow">
        <div class="fg"><label>Name / company</label><input type="text" id="fromName" placeholder="Your Business" oninput="up()"></div>
        <div class="fg"><label>Email</label><input type="email" id="fromEmail" placeholder="you@email.com" oninput="up()"></div>
      </div>
      <div class="frow one"><div class="fg"><label>Address</label><textarea id="fromAddress" rows="2" placeholder="Your address" oninput="up()"></textarea></div></div>

      <div class="stitle" style="margin-top:16px">Client details</div>
      <div class="frow">
        <div class="fg"><label>Client name</label><input type="text" id="toName" placeholder="Client Name" oninput="up()"></div>
        <div class="fg"><label>Client email</label><input type="email" id="toEmail" placeholder="client@email.com" oninput="up()"></div>
      </div>
      <div class="frow one"><div class="fg"><label>Client address</label><textarea id="toAddress" rows="2" placeholder="Client address" oninput="up()"></textarea></div></div>

      <div class="stitle" style="margin-top:16px">Quote details</div>
      <div class="frow three">
        <div class="fg"><label>Quote number</label><input type="text" id="quoteNumber" value="Q-001" oninput="up()"></div>
        <div class="fg"><label>Quote date</label><input type="date" id="quoteDate" oninput="up()"></div>
        <div class="fg"><label>Valid until</label><input type="date" id="validUntil" oninput="up()"></div>
      </div>
      <div class="frow one"><div class="fg"><label>Currency</label>
        <select id="currency" onchange="up()">
          <option value="<%= country.currency %>|<%= country.symbol %>" selected><%= country.currency %> â€” <%= country.symbol %></option>
          <option value="USD|$">USD â€” $</option><option value="GBP|Â£">GBP â€” Â£</option><option value="EUR|â‚¬">EUR â€” â‚¬</option>
          <option value="CAD|CA$">CAD â€” CA$</option><option value="AUD|AU$">AUD â€” AU$</option>
        </select>
      </div></div>

      <div class="stitle" style="margin-top:16px">Line items</div>
      <div class="ih"><span>Description</span><span>Qty</span><span>Rate</span><span>Amount</span><span></span></div>
      <div id="items">
        <div class="ir">
          <input type="text" placeholder="Service description" oninput="up()">
          <input type="number" value="1" min="0" step="any" oninput="up()">
          <input type="number" value="500" min="0" step="any" oninput="up()">
          <div class="lt"><%= country.symbol %>500.00</div>
          <button class="del" onclick="delItem(this)">&#215;</button>
        </div>
      </div>
      <button class="add-btn" onclick="addItem()">+ Add line item</button>

      <div class="frow">
        <div class="fg"><label><%= country.tax %> rate (%)</label><input type="number" id="taxRate" value="<%= country.taxRate %>" min="0" max="100" step="any" oninput="up()"></div>
        <div class="fg"><label>Tax label</label><input type="text" id="taxLabel" value="<%= country.tax %>" oninput="up()"></div>
      </div>
      <div class="disc-row">
        <div class="fg"><label>Discount</label><input type="number" id="discount" placeholder="0" min="0" step="any" oninput="up()"></div>
        <div class="fg"><label>Type</label><select id="discountType" onchange="up()"><option value="fixed">Fixed</option><option value="percent">%</option></select></div>
      </div>

      <div class="totals">
        <div class="trow"><span>Subtotal</span><span id="sub"><%= country.symbol %>0.00</span></div>
        <div class="trow" id="discrow" style="display:none;color:#dc2626"><span id="discLabel">Discount</span><span id="discDisplay">-<%= country.symbol %>0.00</span></div>
        <div class="trow" id="taxrow"><span id="tlabel"><%= country.tax %> (<%= country.taxRate %>%)</span><span id="taxamt"><%= country.symbol %>0.00</span></div>
        <div class="trow grand"><span>Total</span><span id="tot" style="color:var(--blue)"><%= country.symbol %>0.00</span></div>
      </div>

      <div class="stitle" style="margin-top:16px">Notes & terms</div>
      <textarea id="notes" rows="3" placeholder="Payment terms, scope of work..." oninput="up()"></textarea>

      <div class="stitle" style="margin-top:16px">Color</div>
      <div class="colors">
        <div class="cdot on" style="background:#0f4c81" data-c="#0f4c81" onclick="setColor(this)"></div>
        <div class="cdot" style="background:#7c3aed" data-c="#7c3aed" onclick="setColor(this)"></div>
        <div class="cdot" style="background:#059669" data-c="#059669" onclick="setColor(this)"></div>
        <div class="cdot" style="background:#dc2626" data-c="#dc2626" onclick="setColor(this)"></div>
        <div class="cdot" style="background:#d97706" data-c="#d97706" onclick="setColor(this)"></div>
        <div class="cdot" style="background:#1a1a2e" data-c="#1a1a2e" onclick="setColor(this)"></div>
      </div>
      <button class="pdf-btn" id="pbtn" onclick="dlPDF()">&#8595; Download Free PDF Quote</button>
    </div>
  </div>

  <div class="preview-panel">
    <div class="ph"><span>Live Preview</span><span style="font-size:10px;color:#9ca3af">Updates as you type</span></div>
    <iframe id="pframe" title="Quote preview"></iframe>
    <div class="pro-bar">
      <p>PRO: No watermark &bull; Custom logo &bull; Quoteâ†’Invoice</p>
      <a href="<%= gumroadLink %>" target="_blank"><button class="btn-pro" style="font-size:12px;padding:6px 12px;white-space:nowrap">Get PRO</button></a>
    </div>
  </div>
</div>

<div class="content-sec">
  <h2>How to create a <%= country.fullName %> quote</h2>
  <p>Creating a professional quotation for <%= country.fullName %> clients is straightforward with our free generator. The <%= country.currency %> currency and <%= country.taxRate %>% <%= country.tax %> rate are pre-filled automatically.</p>
  <ul>
    <li>Your <%= country.fullName %> business name and address</li>
    <li>Client name and billing address</li>
    <li>A unique quote number and validity date</li>
    <li>Itemised services with quantities and rates in <%= country.currency %></li>
    <li><%= country.tax %> calculated automatically at <%= country.taxRate %>%</li>
    <li>Any discounts applied (fixed or percentage)</li>
    <li>Payment terms in the notes section</li>
  </ul>
</div>

<section class="other">
  <h2>Quote generators for other countries</h2>
  <div class="sgrid">
    <% countries.filter(function(c){ return c.slug !== country.slug; }).forEach(function(c){ %>
    <a href="/free-quote-generator-<%= c.slug %>" class="sl"><%= c.fullName %> (<%= c.currency %>)</a>
    <% }) %>
  </div>
</section>

<footer>
  <a href="/">Home</a><a href="/#pricing">Pricing</a><a href="/#templates">Templates</a><a href="/activate">Activate PRO</a>
  <p style="margin-top:12px">&#169; 2026 GetQuotationMaker â€” Free Quote Generator</p>
</footer>

<script>
let color='#0f4c81';
function setColor(el){document.querySelectorAll('.cdot').forEach(d=>d.classList.remove('on'));el.classList.add('on');color=el.dataset.c;up();}
function sym(){return document.getElementById('currency').value.split('|')[1]||'$';}
function getItems(){const rows=document.querySelectorAll('.ir');const r=[];rows.forEach(row=>{const ins=row.querySelectorAll('input');if(ins.length>=3){const desc=ins[0].value,qty=parseFloat(ins[1].value)||0,rate=parseFloat(ins[2].value)||0;row.querySelector('.lt').textContent=sym()+(qty*rate).toFixed(2);r.push({desc,qty,rate});}});return r;}
function calcs(items){const s=sym();const sub=items.reduce((a,i)=>a+i.qty*i.rate,0);const tr=parseFloat(document.getElementById('taxRate').value)||0;const tl=document.getElementById('taxLabel').value||'Tax';const disc=parseFloat(document.getElementById('discount').value)||0;const discType=document.getElementById('discountType').value;const discAmt=discType==='percent'?sub*(disc/100):disc;const afterDisc=sub-discAmt;const ta=afterDisc*(tr/100);const tot=afterDisc+ta;document.getElementById('sub').textContent=s+sub.toFixed(2);document.getElementById('tot').textContent=s+tot.toFixed(2);const discrow=document.getElementById('discrow');if(discAmt>0){discrow.style.display='flex';document.getElementById('discLabel').textContent='Discount'+(discType==='percent'?' ('+disc+'%)':'');document.getElementById('discDisplay').textContent='-'+s+discAmt.toFixed(2);}else discrow.style.display='none';const taxrow=document.getElementById('taxrow');if(tr>0){taxrow.style.display='flex';document.getElementById('tlabel').textContent=tl+' ('+tr+'%)';document.getElementById('taxamt').textContent=s+ta.toFixed(2);}else taxrow.style.display='none';return{sub,ta,tot,tr,tl,discAmt,discType,disc};}
function buildPreview(d){const s=d.symbol||'$';const c=d.color||'#0f4c81';const rows=(d.items||[]).map(i=>'<tr><td style="padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:12px">'+(i.desc||'')+'</td><td style="padding:7px 6px;border-bottom:1px solid #f0f0f0;text-align:center;font-size:12px;color:#666">'+i.qty+'</td><td style="padding:7px 6px;border-bottom:1px solid #f0f0f0;text-align:right;font-size:12px;color:#666">'+s+parseFloat(i.rate).toFixed(2)+'</td><td style="padding:7px 0 7px 6px;border-bottom:1px solid #f0f0f0;text-align:right;font-size:12px;font-weight:700">'+s+(i.qty*i.rate).toFixed(2)+'</td></tr>').join('');const discRow=d.discAmt>0?'<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:11px;color:#dc2626;border-top:1px solid #f0f0f0"><span>Discount'+(d.discType==='percent'?' ('+d.disc+'%)':'')+'</span><span>-'+s+d.discAmt.toFixed(2)+'</span></div>':'';const taxRow=d.tr>0?'<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:11px;color:#666;border-top:1px solid #f0f0f0"><span>'+(d.tl||'Tax')+' ('+d.tr+'%)</span><span>'+s+d.ta.toFixed(2)+'</span></div>':'';return'<!DOCTYPE html><html><head><link rel="icon" type="image/svg+xml" href="/favicon.svg"><meta charset="UTF-8"><style>body{font-family:Arial,sans-serif;color:#1a1a1a;margin:0;padding:20px;font-size:12px}*{box-sizing:border-box}</style></head><body><div style="display:flex;justify-content:space-between;margin-bottom:16px;padding-bottom:12px;border-bottom:3px solid '+c+'"><div><div style="font-size:20px;font-weight:800;color:'+c+'">QUOTATION</div><div style="color:#999;font-size:10px">#'+(d.quoteNumber||'Q-001')+'</div></div><div style="text-align:right"><div style="font-weight:700;font-size:13px">'+(d.fromName||'')+'</div><div style="color:#666;font-size:10px">'+(d.fromEmail||'')+'</div></div></div><div style="display:flex;justify-content:space-between;margin-bottom:14px"><div><div style="font-size:9px;font-weight:700;color:#999;text-transform:uppercase;margin-bottom:3px">Prepared For</div><div style="font-weight:700;font-size:12px">'+(d.toName||'')+'</div></div><div style="text-align:right"><div style="font-size:9px;font-weight:700;color:#999;text-transform:uppercase">Quote Date</div><div style="font-weight:700;font-size:11px">'+(d.quoteDate||'')+'</div>'+(d.validUntil?'<div style="font-size:9px;font-weight:700;color:#999;text-transform:uppercase;margin-top:5px">Valid Until</div><div style="font-weight:700;font-size:11px;color:#dc2626">'+d.validUntil+'</div>':'')+'</div></div><table style="width:100%;border-collapse:collapse;margin-bottom:12px"><thead><tr style="background:'+c+'"><th style="padding:7px 0;text-align:left;font-size:9px;font-weight:700;color:#fff">DESCRIPTION</th><th style="padding:7px 6px;text-align:center;font-size:9px;font-weight:700;color:#fff">QTY</th><th style="padding:7px 6px;text-align:right;font-size:9px;font-weight:700;color:#fff">RATE</th><th style="padding:7px 0 7px 6px;text-align:right;font-size:9px;font-weight:700;color:#fff">AMOUNT</th></tr></thead><tbody>'+rows+'</tbody></table><div style="display:flex;justify-content:flex-end;margin-bottom:12px"><div style="min-width:180px"><div style="display:flex;justify-content:space-between;padding:3px 0;font-size:11px;color:#666"><span>Subtotal</span><span>'+s+(d.sub||0).toFixed(2)+'</span></div>'+discRow+taxRow+'<div style="display:flex;justify-content:space-between;padding:7px 0 3px;font-size:15px;font-weight:800;border-top:2px solid '+c+';margin-top:3px"><span>Total</span><span style="color:'+c+'">'+s+(d.tot||0).toFixed(2)+'</span></div></div></div>'+(d.notes?'<div style="background:#f8f9fa;border-left:3px solid '+c+';padding:8px 12px;font-size:11px;color:#555">'+d.notes+'</div>':'')+'<div style="text-align:center;margin-top:18px;padding-top:10px;border-top:1px solid #eee"><p style="font-size:9px;color:#bbb;margin:0">GetQuotationMaker.com â€” Free Plan</p></div></body></html>';}
function up(){const items=getItems();const{sub,ta,tot,tr,tl,discAmt,discType,disc}=calcs(items);const s=sym();const d={fromName:document.getElementById('fromName').value,fromEmail:document.getElementById('fromEmail').value,fromAddress:document.getElementById('fromAddress').value,toName:document.getElementById('toName').value,toEmail:document.getElementById('toEmail').value,toAddress:document.getElementById('toAddress').value,quoteNumber:document.getElementById('quoteNumber').value,quoteDate:document.getElementById('quoteDate').value,validUntil:document.getElementById('validUntil').value,notes:document.getElementById('notes').value,tr,tl,ta,sub,tot,discAmt,discType,disc,items,color,symbol:s};document.getElementById('pframe').srcdoc=buildPreview(d);}
function addItem(){const c=document.getElementById('items');const div=document.createElement('div');div.className='ir';div.innerHTML='<input type="text" placeholder="Service" oninput="up()"><input type="number" value="1" min="0" step="any" oninput="up()"><input type="number" value="0" min="0" step="any" oninput="up()"><div class="lt">$0.00</div><button class="del" onclick="delItem(this)">&#215;</button>';c.appendChild(div);up();}
function delItem(btn){if(document.querySelectorAll('.ir').length>1){btn.parentElement.remove();up();}}
async function dlPDF(){const btn=document.getElementById('pbtn');btn.textContent='Generating...';btn.disabled=true;const items=getItems();const{sub,ta,tot,tr,tl,discAmt,discType,disc}=calcs(items);const s=sym();const d={fromName:document.getElementById('fromName').value,fromEmail:document.getElementById('fromEmail').value,fromAddress:document.getElementById('fromAddress').value,toName:document.getElementById('toName').value,toEmail:document.getElementById('toEmail').value,toAddress:document.getElementById('toAddress').value,quoteNumber:document.getElementById('quoteNumber').value,quoteDate:document.getElementById('quoteDate').value,validUntil:document.getElementById('validUntil').value,notes:document.getElementById('notes').value,taxRate:tr,taxLabel:tl,taxAmt:ta,subtotal:sub,total:tot,discount:disc,discountType:discType,items,color,symbol:s};try{const res=await fetch('/generate-pdf',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({quoteData:JSON.stringify(d)})});if(!res.ok)throw new Error();const blob=await res.blob();const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='quote-'+(d.quoteNumber||'Q-001')+'.pdf';a.click();URL.revokeObjectURL(url);btn.innerHTML='&#8595; Download Free PDF Quote';btn.disabled=false;}catch(e){btn.textContent='Error â€” try again';btn.disabled=false;}}
const today=new Date().toISOString().split('T')[0];const plus30=new Date(Date.now()+30*864e5).toISOString().split('T')[0];
document.getElementById('quoteDate').value=today;document.getElementById('validUntil').value=plus30;up();
</script>
