<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Quoting Guides & Resources | GetQuotationMaker Blog</title>
<meta name="description" content="Free guides on how to write professional quotes, price your work, and win more jobs. For freelancers, tradespeople and small businesses.">
<link rel="canonical" href="<%= siteUrl %>/blog">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--blue:#0f4c81;--blue-light:#1a6aad;--blue-pale:#e8f0f8;--green:#0d9f6b;--dark:#0d1117;--text:#1a1a2e;--muted:#6b7280;--border:#e5e7eb;--bg:#f7f8fc;--white:#ffffff}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text)}
h1,h2,h3,.logo{font-family:'Sora',sans-serif}
a{color:var(--blue);text-decoration:none}
nav{background:var(--white);border-bottom:1px solid var(--border);height:62px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;position:sticky;top:0;z-index:100}
.logo{font-size:17px;font-weight:800;color:var(--dark)}.logo span{color:var(--blue)}
.nav-r{display:flex;gap:6px;align-items:center}
.nav-link{color:var(--muted);font-size:13px;font-weight:500;padding:6px 12px;border-radius:7px}
.nav-link:hover{background:var(--blue-pale);color:var(--blue)}
.btn-pro{background:var(--blue);color:#fff;border:none;padding:8px 18px;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer;font-family:'Sora',sans-serif}
.hero{background:var(--white);border-bottom:1px solid var(--border);padding:48px 20px 40px;text-align:center}
.hero h1{font-size:clamp(24px,4vw,36px);font-weight:800;letter-spacing:-0.5px;margin-bottom:12px}
.hero p{color:var(--muted);font-size:15px;max-width:520px;margin:0 auto}
.container{max-width:980px;margin:0 auto;padding:40px 20px}
.sec-title{font-size:20px;font-weight:800;margin-bottom:22px;letter-spacing:-0.3px}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:52px}
@media(max-width:700px){.blog-grid{grid-template-columns:1fr}}
.blog-card{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:20px;transition:box-shadow .15s,transform .15s;display:block}
.blog-card:hover{box-shadow:0 6px 20px rgba(0,0,0,.08);transform:translateY(-2px)}
.tag{font-size:10px;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.5px;font-family:'Sora',sans-serif;margin-bottom:8px}
.blog-card h2{font-size:14px;font-weight:700;line-height:1.5;margin-bottom:8px;color:var(--text)}
.blog-card p{font-size:12px;color:var(--muted);line-height:1.5;margin-bottom:12px}
.meta{font-size:11px;color:#9ca3af;display:flex;gap:12px}
.howto-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:52px}
@media(max-width:700px){.howto-grid{grid-template-columns:1fr}}
.howto-card{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:16px 18px;display:flex;align-items:center;gap:12px;transition:border-color .15s}
.howto-card:hover{border-color:var(--blue)}
.hi{width:34px;height:34px;background:var(--blue-pale);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.howto-card h3{font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px}
.howto-card p{font-size:11px;color:var(--muted);line-height:1.4}
.cta-strip{background:linear-gradient(135deg,#0f4c81,#1a6aad);border-radius:14px;padding:28px 32px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:40px}
.cta-strip h3{font-size:18px;font-weight:800;color:#fff;letter-spacing:-0.3px}
.cta-strip p{font-size:13px;color:rgba(255,255,255,.8);margin-top:4px}
.cta-strip a{background:#fff;color:var(--blue);padding:10px 22px;border-radius:8px;font-weight:700;font-size:13px;font-family:'Sora',sans-serif;white-space:nowrap}
footer{background:var(--dark);color:#6b7280;padding:28px 20px;text-align:center;font-size:12px}
footer a{color:#6b7280;margin:0 10px}
footer a:hover{color:#fff}
</style>
</head>
<body>
<nav>
  <a href="/"><div class="logo">Get<span>Quotation</span>Maker</div></a>
  <div class="nav-r">
    <a href="/" class="nav-link">Generator</a>
    <a href="/blog" class="nav-link">Blog</a>
    <a href="<%= gumroadLink %>" target="_blank"><button class="btn-pro">Get PRO $9</button></a>
  </div>
</nav>

<section class="hero">
  <h1>Quoting Guides & Resources</h1>
  <p>Free guides to help freelancers, tradespeople and small businesses write professional quotes, price their work, and win more jobs.</p>
</section>

<div class="container">
  <div class="cta-strip">
    <div>
      <h3>Create a free quote right now</h3>
      <p>No signup. No watermark on PRO. Professional PDF in 60 seconds.</p>
    </div>
    <a href="/">Create Free Quote →</a>
  </div>

  <div class="sec-title">Latest guides</div>
  <div class="blog-grid">
    <% posts.forEach(function(post) { %>
    <a href="/blog/<%= post.slug %>" class="blog-card">
      <div class="tag"><%= post.category %></div>
      <h2><%= post.title %></h2>
      <p><%= post.desc.substring(0,95) %>...</p>
      <div class="meta"><span><%= post.date %></span><span><%= post.readTime %></span></div>
    </a>
    <% }) %>
  </div>

  <div class="sec-title">How-to guides</div>
  <div class="howto-grid">
    <% howTo.forEach(function(page) { %>
    <a href="/<%= page.slug %>" class="howto-card">
      <div class="hi">&#128196;</div>
      <div>
        <h3><%= page.title %></h3>
        <p><%= page.desc.substring(0,80) %>...</p>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<footer>
  <a href="/">Quote Generator</a><a href="/blog">Blog</a><a href="/#pricing">Pricing</a><a href="/activate">Activate PRO</a>
  <p style="margin-top:12px">&#169; 2026 GetQuotationMaker — Free Quote Generator</p>
</footer>
</body>
</html>
